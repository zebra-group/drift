{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/renderer",
    "rootDir": "./src",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "preserve"
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
